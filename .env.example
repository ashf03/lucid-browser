# Backup LLM Provider: OpenAI GPT
VITE_OPENAI_API_KEY=
VITE_OPENAI_ORGANIZATION_ID=

# Mapbox API
VITE_MAPBOX_ACCESS_TOKEN=

# Eleven Labs API (text-to-speech / speech-to-text)
ELEVEN_LABS_API_KEY=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: encrypt local auth storage (electron-store)
AUTH_STORE_ENCRYPTION_KEY=
